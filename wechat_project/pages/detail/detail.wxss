.page {
  min-height: 100vh;
  background: #0a0e17;
  padding-bottom: calc(48rpx + env(safe-area-inset-bottom));
}

/* 导航栏 */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 300;
  background: rgba(10, 14, 23, 0.96);
  backdrop-filter: blur(12px);
  border-bottom: 1rpx solid #2b2f36;
}

.nav-content {
  display: flex;
  align-items: center;
  padding: 8rpx 16rpx 12rpx;
  gap: 12rpx;
}

.back-btn, .watch-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.back-btn {
  color: #00d4ff;
  background: rgba(0, 212, 255, 0.08);
}

.watch-btn {
  color: #f0b90b;
  background: rgba(240, 185, 11, 0.1);
}

.watch-btn.placeholder {
  opacity: 0;
  pointer-events: none;
}

.nav-title {
  flex: 1;
  min-width: 0;
}

.nav-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #e8edf5;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.nav-code {
  display: block;
  font-size: 20rpx;
  color: #5c6578;
  font-family: 'SF Mono', 'Menlo', monospace;
  margin-top: 2rpx;
}

/* 未找到 */
.not-found {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx;
}

.not-found-icon {
  font-size: 80rpx;
  color: #00d4ff;
  opacity: 0.3;
  margin-bottom: 32rpx;
}

.not-found-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #8b95a8;
  margin-bottom: 12rpx;
}

.not-found-desc {
  font-size: 24rpx;
  color: #5c6578;
}

/* 头部信息 */
.detail-header {
  padding: 12rpx 24rpx 0;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: 12rpx;
}

.price-main {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  flex: 1;
  min-width: 200rpx;
}

.price-value {
  font-size: 56rpx;
  font-weight: 700;
  color: #e8edf5;
  font-family: 'SF Mono', 'Menlo', monospace;
  letter-spacing: -1rpx;
}

.price-change {
  font-size: 28rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.price-change.up { color: #0ecb81; }
.price-change.down { color: #f6465d; }

.badge-group {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
}

.industry-badge {
  font-size: 22rpx;
  color: #00d4ff;
  background: rgba(0, 212, 255, 0.1);
  border: 1rpx solid rgba(0, 212, 255, 0.25);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
}

.resonance-badge {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  border: 1rpx solid;
}

.resonance-badge.strong {
  color: #0ecb81;
  background: rgba(14, 203, 129, 0.1);
  border-color: rgba(14, 203, 129, 0.35);
}

.resonance-badge.medium {
  color: #f0b90b;
  background: rgba(240, 185, 11, 0.1);
  border-color: rgba(240, 185, 11, 0.3);
}

.resonance-badge.weak {
  color: #848e9c;
  background: rgba(132, 142, 156, 0.1);
  border-color: rgba(132, 142, 156, 0.3);
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.tag {
  font-size: 20rpx;
  color: #848e9c;
  background: rgba(43, 47, 54, 0.6);
  border: 1rpx solid #2b2f36;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.summary-box {
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(0, 212, 255, 0.05);
  border-left: 4rpx solid #00d4ff;
  border-radius: 0 8rpx 8rpx 0;
}

.summary-text {
  font-size: 24rpx;
  color: #8b95a8;
  line-height: 1.7;
}

/* K 线区 */
.kline-section {
  margin: 8rpx 0 0;
}

.period-sticky {
  position: sticky;
  z-index: 200;
  padding: 8rpx 24rpx;
  background: #0a0e17;
  border-bottom: 1rpx solid #2b2f36;
}

.period-sticky .period-switcher {
  padding: 0;
  margin: 0;
}

.period-sticky .period-tabs {
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
}

.period-sticky .period-toolbar {
  gap: 8rpx;
}

.period-sticky .flip-btn {
  height: 56rpx;
  width: 56rpx;
}

.kline-panel {
  margin: 12rpx 24rpx 0;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
  overflow: hidden;
  background: #1e2026;
}

.kline-panel .mini-kline.size-card {
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}

/* 通用区块 */
.section {
  padding: 24rpx 24rpx 0;
}

.section-tight {
  padding-top: 16rpx;
}

.section-last {
  padding-bottom: 16rpx;
}

.section-head {
  margin-bottom: 16rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #e8edf5;
}

.section-sub {
  display: block;
  font-size: 22rpx;
  color: #5c6578;
  margin-top: 6rpx;
}

.card-block {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  padding: 20rpx;
}

/* 企业阶段 */
.stage-card {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.stage-badge {
  display: inline-block;
  font-size: 24rpx;
  font-weight: 600;
  padding: 6rpx 16rpx;
  border: 1rpx solid;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.stage-desc {
  display: block;
  font-size: 24rpx;
  color: #8b95a8;
  line-height: 1.7;
}

.stage-hint {
  display: block;
  font-size: 22rpx;
  color: #00d4ff;
  line-height: 1.6;
  margin-top: 10rpx;
  opacity: 0.85;
}

.portrait-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.portrait-item {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 10rpx;
  padding: 14rpx;
}

.portrait-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.portrait-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #e8edf5;
}

.portrait-score {
  font-size: 22rpx;
  color: #0ecb81;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.portrait-text {
  font-size: 20rpx;
  color: #5c6578;
  line-height: 1.45;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* 健康度 */
.health-card {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  padding: 24rpx;
}

.health-score-wrap {
  display: flex;
  gap: 24rpx;
  align-items: flex-start;
}

.score-ring {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #0ecb81;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  background: rgba(14, 203, 129, 0.08);
}

.score-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #0ecb81;
  line-height: 1;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.score-unit {
  font-size: 18rpx;
  color: #848e9c;
  margin-top: 4rpx;
}

.health-info {
  flex: 1;
  min-width: 0;
}

.health-rank {
  display: block;
  font-size: 24rpx;
  color: #e8edf5;
  margin-bottom: 16rpx;
}

.health-bars {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hbar-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hbar-label {
  font-size: 20rpx;
  color: #848e9c;
  width: 48rpx;
  flex-shrink: 0;
}

.hbar-track {
  flex: 1;
  height: 8rpx;
  background: #2b2f36;
  border-radius: 4rpx;
  overflow: hidden;
}

.hbar-fill {
  height: 100%;
  background: #0ecb81;
  border-radius: 4rpx;
}

.hbar-fill.growth { background: #00d4ff; }
.hbar-fill.debt { background: #f0b90b; }
.hbar-fill.op { background: #a78bfa; }

.hbar-val {
  font-size: 20rpx;
  color: #848e9c;
  width: 48rpx;
  text-align: right;
  font-family: 'SF Mono', 'Menlo', monospace;
}

/* 关键指标 */
.metrics-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.metric-item {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 10rpx;
  padding: 16rpx;
  text-align: center;
}

.metric-label {
  display: block;
  font-size: 20rpx;
  color: #5c6578;
  margin-bottom: 8rpx;
}

.metric-value {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #e8edf5;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.page-footer {
  text-align: center;
  padding: 32rpx 0 16rpx;
}

.page-footer text {
  font-size: 20rpx;
  color: #3d4556;
}
