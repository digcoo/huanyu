.page {
  min-height: 100vh;
  background: #0a0e17;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #0a0e17;
  border-bottom: 1rpx solid #2b2f36;
}

.period-bar {
  margin: 0 24rpx;
  padding: 0 0 12rpx;
  box-sizing: border-box;
}

.period-bar .period-switcher {
  width: 100%;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.period-bar .period-toolbar {
  width: 100%;
  gap: 8rpx;
  box-sizing: border-box;
}

.period-bar .period-tabs {
  flex: 1;
  min-width: 0;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
}

.period-bar .flip-btn {
  height: 56rpx;
  width: 56rpx;
}

.nav-content {
  padding: 12rpx 32rpx 8rpx;
}

.nav-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8edf5;
}

.page-count {
  font-size: 24rpx;
  color: #00d4ff;
  font-weight: 500;
}

.content {
  box-sizing: border-box;
}

.tabs-wrap {
  background: #0a0e17;
  padding: 2rpx 0 0;
}

.list-wrap {
  padding: 0 24rpx;
}

.list-hint {
  font-size: 20rpx;
  color: #3d4556;
  text-align: center;
  padding: 6rpx 0 10rpx;
}

.list-footer {
  font-size: 20rpx;
  color: #3d4556;
  text-align: center;
  padding: 24rpx 0 48rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.empty.filter-empty {
  padding-top: 120rpx;
}

.empty-icon-wrap {
  font-size: 80rpx;
  color: #3d4556;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #8b95a8;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #5c6578;
  text-align: center;
  line-height: 1.8;
}

.empty-action {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #0a0e17;
  background: #00d4ff;
  border-radius: 12rpx;
  font-weight: 600;
}
