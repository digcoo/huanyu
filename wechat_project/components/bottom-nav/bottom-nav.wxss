.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: calc(100rpx + env(safe-area-inset-bottom));
  padding-bottom: env(safe-area-inset-bottom);
  background: #0f1419;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  display: flex;
  z-index: 100;
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 4rpx;
}

.nav-icon-wrap {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.nav-icon {
  font-size: 36rpx;
  color: #5c6578;
}

.nav-label {
  font-size: 20rpx;
  color: #5c6578;
}

.nav-item.active .nav-icon,
.nav-item.active .nav-label {
  color: #00d4ff;
}
