.trend-chart {
  width: 100%;
}

.trend-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.mini-chart {
  background: #161a1e;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
  padding: 10rpx 10rpx 8rpx;
  overflow: hidden;
}

.mini-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 6rpx;
}

.mini-name {
  font-size: 20rpx;
  color: #848e9c;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-change {
  font-size: 20rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', monospace;
  flex-shrink: 0;
}

.mini-change.up { color: #0ecb81; }
.mini-change.down { color: #f6465d; }
.mini-change.flat { color: #848e9c; }

.compare-legend {
  display: flex;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.leg-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
  color: #5c6578;
}

.leg-line {
  width: 20rpx;
  height: 4rpx;
  border-radius: 2rpx;
}

.leg-line.dashed {
  background: transparent;
  border-top: 2rpx dashed #848e9c;
  height: 0;
  width: 20rpx;
}

.mini-area {
  position: relative;
  width: 100%;
  height: 120rpx;
}

.mini-canvas {
  display: block;
  width: 100%;
  height: 120rpx;
}

.year-axis {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 2rpx 4rpx 4rpx;
}

.year-label {
  font-size: 16rpx;
  color: #3d4556;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.mini-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 4rpx;
  padding-top: 2rpx;
  border-top: 1rpx solid rgba(43, 47, 54, 0.5);
}

.foot-item {
  font-size: 18rpx;
  color: #5c6578;
  font-family: 'SF Mono', 'Menlo', monospace;
  flex: 1;
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.foot-item.highlight {
  color: #c8d0dc;
  text-align: right;
}

.foot-item.industry {
  color: #848e9c;
  text-align: right;
}

.foot-arrow {
  font-size: 16rpx;
  color: #3d4556;
  flex-shrink: 0;
}
