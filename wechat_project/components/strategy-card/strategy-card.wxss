.card-wrapper {
  position: relative;
  margin-bottom: 24rpx;
  overflow: hidden;
  border-radius: 20rpx;
}

.action-bg {
  position: absolute;
  top: 0;
  bottom: 0;
  width: 140rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  transition: opacity 0.15s;
}

.action-bg.visible {
  opacity: 1;
}

.action-bg.ignore {
  left: 0;
  background: linear-gradient(90deg, rgba(248, 113, 113, 0.2), transparent);
}

.action-bg.watchlist {
  right: 0;
  background: linear-gradient(-90deg, rgba(0, 212, 255, 0.2), transparent);
}

.action-icon {
  font-size: 36rpx;
  margin-bottom: 4rpx;
}

.action-bg.ignore .action-icon,
.action-bg.ignore .action-text {
  color: #f87171;
}

.action-bg.watchlist .action-icon,
.action-bg.watchlist .action-text {
  color: #00d4ff;
}

.action-text {
  font-size: 22rpx;
  font-weight: 500;
}

.strategy-card {
  background: #141b26;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  padding: 24rpx;
  position: relative;
  z-index: 1;
  transition: transform 0.05s linear;
}

.strategy-card.swiping {
  transition: none;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.stock-info {
  display: flex;
  flex-direction: column;
}

.stock-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #e8edf5;
  letter-spacing: 1rpx;
}

.stock-code {
  font-size: 22rpx;
  color: #5c6578;
  margin-top: 4rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.price-info {
  text-align: right;
}

.stock-price {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #e8edf5;
  font-variant-numeric: tabular-nums;
}

.stock-change {
  display: block;
  font-size: 24rpx;
  margin-top: 4rpx;
  font-variant-numeric: tabular-nums;
}

.stock-change.up { color: #0ecb81; }
.stock-change.down { color: #f6465d; }

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.tag {
  font-size: 20rpx;
  padding: 6rpx 14rpx;
  border-radius: 8rpx;
  background: rgba(0, 212, 255, 0.08);
  color: #00d4ff;
  border: 1rpx solid rgba(0, 212, 255, 0.15);
}

.tag:nth-child(2n) {
  background: rgba(255, 149, 0, 0.08);
  color: #ff9500;
  border-color: rgba(255, 149, 0, 0.15);
}

.tag:nth-child(3n) {
  background: rgba(167, 139, 250, 0.08);
  color: #a78bfa;
  border-color: rgba(167, 139, 250, 0.15);
}

.chart-empty {
  margin-top: 16rpx;
  height: 280rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e2026;
  border-radius: 10rpx;
  border: 1rpx solid #2b2f36;
  font-size: 24rpx;
  color: #848e9c;
}

.summary {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
  margin-top: 16rpx;
  padding: 16rpx;
  background: rgba(255, 149, 0, 0.06);
  border-radius: 12rpx;
  border-left: 4rpx solid #ff9500;
}

.summary-icon {
  font-size: 24rpx;
  flex-shrink: 0;
}

.summary-text {
  font-size: 24rpx;
  color: #8b95a8;
  line-height: 1.6;
}

.swipe-hint {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.04);
}

.hint-left, .hint-right {
  font-size: 20rpx;
  color: #3d4556;
}

.hint-left { color: rgba(248, 113, 113, 0.5); }
.hint-right { color: rgba(0, 212, 255, 0.5); }
