<scroll-view class="market-tabs {{compact ? 'compact' : ''}}" scroll-x enhanced show-scrollbar="{{false}}">
  <view class="tabs-inner">
    <view
      wx:for="{{markets}}"
      wx:key="id"
      class="tab-item {{activeMarket === item.id ? 'active' : ''}}"
      data-id="{{item.id}}"
      bindtap="onTabTap"
    >
      <text class="tab-icon">{{item.icon}}</text>
      <text class="tab-name">{{item.name}}</text>
      <view wx:if="{{activeMarket === item.id}}" class="tab-indicator"></view>
    </view>
  </view>
</scroll-view>
