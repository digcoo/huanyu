.market-tabs {
  width: 100%;
  white-space: nowrap;
  background: #0a0e17;
  padding: 0 8rpx;
}

.tabs-inner {
  display: inline-flex;
  padding: 16rpx 8rpx 12rpx;
  gap: 8rpx;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
  min-width: 100rpx;
}

.tab-item.active {
  background: rgba(0, 212, 255, 0.1);
}

.tab-icon {
  font-size: 28rpx;
  margin-bottom: 4rpx;
}

.tab-name {
  font-size: 24rpx;
  color: #6b7280;
  font-weight: 500;
}

.tab-item.active .tab-name {
  color: #00d4ff;
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 32rpx;
  height: 4rpx;
  background: #00d4ff;
  border-radius: 2rpx;
}
