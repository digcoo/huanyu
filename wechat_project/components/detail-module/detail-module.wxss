.detail-module {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.module-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 20rpx 20rpx 0;
}

.head-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 16rpx;
}

.color-bar {
  width: 6rpx;
  height: 48rpx;
  border-radius: 0 4rpx 4rpx 0;
  flex-shrink: 0;
}

.module-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e8edf5;
}

.module-insight {
  display: block;
  font-size: 20rpx;
  color: #5c6578;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  max-width: 520rpx;
}

.toggle-icon {
  font-size: 32rpx;
  color: #848e9c;
  padding: 0 20rpx;
  line-height: 1;
}

.module-body {
  padding: 0 20rpx 20rpx;
}

.insight-box {
  padding: 16rpx;
  background: rgba(43, 47, 54, 0.4);
  border-radius: 8rpx;
  border-left: 4rpx solid #2b2f36;
  margin-bottom: 16rpx;
}

.insight-text {
  font-size: 24rpx;
  color: #8b95a8;
  line-height: 1.7;
}
