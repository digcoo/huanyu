<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="com.yh.bigdata.tts.common.dao.StockTargetMapper" >
    <resultMap id="BaseResultMap" type="com.yh.bigdata.tts.common.model.StockTarget" >
        <result column="day" property="day" jdbcType="DATE" />
        <result column="code" property="code" jdbcType="VARCHAR" />
        <result column="name" property="name" jdbcType="VARCHAR" />
        <result column="close" property="close" jdbcType="DOUBLE" />
        <result column="strategy" property="strategy" jdbcType="VARCHAR" />
        <result column="new_flag" property="newFlag" jdbcType="TINYINT" />
        <result column="change_rate" property="changeRate" jdbcType="DOUBLE" />
    </resultMap>

    <sql id="Base_Column_List" >
      day, code, name, `close`, strategy,new_flag, change_rate
    </sql>

    <insert id="insert" parameterType="com.yh.bigdata.tts.common.model.StockTarget" >
        insert into stock_target (day, code, name, `close`, strategy, new_flag, change_rate, create_time, update_time)
        values (#{day}, #{code}, #{name}, #{close}, #{strategy}, #{newFlag}, #{changeRate} , now(), now())
    </insert>

    <update id="update" parameterType="com.yh.bigdata.tts.common.model.StockTarget" >
        update stock_target
        <set >
            name = #{name},
            `close` = #{close},
            new_flag = #{newFlag},
            change_rate = #{changeRate},
            update_time = now()
        </set>
        where day = #{day} and code = #{code} and strategy = #{strategy}
    </update>

    <select id="selectByPrimaryKey" resultMap="BaseResultMap" >
        select * from stock_target where day = #{day} and code = #{code} and strategy = #{strategy}
    </select>

    <select id="selectLatestDay" resultType="String">
        select distinct day from stock_target order by day desc limit 1
    </select>

    <select id="selectListByDay" resultMap="BaseResultMap" >
        select * from stock_target where day = #{day}
    </select>

</mapper>