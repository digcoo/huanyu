.page {
  min-height: 100vh;
  background: #0a0e17;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: #0a0e17;
  border-bottom: 1rpx solid #2b2f36;
}

.period-bar {
  margin: 0 24rpx;
  padding: 0 0 12rpx;
  box-sizing: border-box;
}

.period-bar .period-switcher {
  width: 100%;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.period-bar .period-toolbar {
  width: 100%;
  gap: 8rpx;
  box-sizing: border-box;
}

.period-bar .period-tabs {
  flex: 1;
  min-width: 0;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
}

.period-bar .flip-btn {
  height: 56rpx;
  width: 56rpx;
}

.nav-content {
  padding: 12rpx 32rpx 16rpx;
}

.nav-title-row {
  display: flex;
  align-items: baseline;
  gap: 16rpx;
  margin-bottom: 6rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #e8edf5;
}

.page-count {
  font-size: 24rpx;
  color: #00d4ff;
  font-weight: 500;
}

.page-sub {
  font-size: 22rpx;
  color: #5c6578;
}

.content {
  box-sizing: border-box;
}

.summary-card {
  margin: 16rpx 24rpx 0;
  padding: 20rpx;
  background: #161a1e;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
}

.kpi-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12rpx;
}

.kpi-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.kpi-value {
  font-size: 28rpx;
  font-weight: 700;
  color: #e8edf5;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.kpi-value.accent { color: #00d4ff; }
.kpi-value.up { color: #f6465d; }
.kpi-value.down { color: #0ecb81; }

.kpi-label {
  font-size: 20rpx;
  color: #848e9c;
}

.filter-bar {
  display: flex;
  gap: 12rpx;
  padding: 16rpx 24rpx 8rpx;
}

.filter-chip {
  padding: 10rpx 24rpx;
  font-size: 24rpx;
  color: #848e9c;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 999rpx;
}

.filter-chip.active {
  color: #f0b90b;
  background: rgba(240, 185, 11, 0.12);
  border-color: rgba(240, 185, 11, 0.35);
}

.list-wrap {
  padding: 8rpx 24rpx 0;
}

.list-footer {
  font-size: 20rpx;
  color: #3d4556;
  text-align: center;
  padding: 24rpx 0 48rpx;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 160rpx 48rpx;
}

.empty.filter-empty {
  padding-top: 80rpx;
}

.empty-icon-wrap {
  font-size: 80rpx;
  color: #3d4556;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 24rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #8b95a8;
  margin-bottom: 16rpx;
}

.empty-desc {
  font-size: 24rpx;
  color: #5c6578;
  text-align: center;
  line-height: 1.8;
}

.empty-action {
  margin-top: 40rpx;
  padding: 16rpx 48rpx;
  font-size: 28rpx;
  color: #0a0e17;
  background: #00d4ff;
  border-radius: 12rpx;
  font-weight: 600;
}
