<view class="page">

  <!-- 品牌区：滚动时吸顶 -->

  <view class="nav-sticky" style="padding-top: {{statusBarHeight}}px">

    <view class="nav-content" style="padding-right: {{navPaddingRight}}px">

      <view class="brand">

        <text class="brand-logo">◈</text>

        <view class="brand-text">

          <text class="brand-name">Atlas</text>

          <text class="brand-sub">寰宇全息投研助手</text>

        </view>

      </view>

      <view class="search-btn" bindtap="onOpenSearch">
        <text class="search-icon">⌕</text>
      </view>

    </view>

  </view>



  <market-tabs

    markets="{{markets}}"

    activeMarket="{{activeMarket}}"

    bind:change="onMarketChange"
    bind:disabled="onMarketDisabled"
  />



  <view class="chart-block">

    <view class="market-panel">

      <index-chart indices="{{indices}}" activePeriod="{{activePeriod}}" flipped="{{klineFlipped}}" />

    </view>

  </view>



  <!-- 周期 + 策略：滚过 K 线后吸顶，叠在品牌区下方 -->

  <view class="toolbar-sticky" style="top: {{toolbarStickyTop}}px">

    <view class="toolbar-inner">

      <view class="period-bar">

        <period-switcher

          activePeriod="{{activePeriod}}"

          flipped="{{klineFlipped}}"

          bind:change="onPeriodChange"

          bind:flip="onFlipKline"

        />

      </view>

      <strategy-tabs

        strategies="{{strategies}}"

        activeStrategy="{{activeStrategy}}"

        bind:change="onStrategyChange"

      />

    </view>

  </view>



  <view class="recommend-list">

    <view class="list-header">

      <view class="list-header-main">
        <text class="list-subtitle">{{activeStrategyMeta.desc}}</text>
        <text wx:if="{{paramsSummary}}" class="list-params">{{paramsSummary}}</text>
      </view>

      <view wx:if="{{showStrategyParams}}" class="list-header-actions">
        <view
          class="params-btn rescan-btn {{rescanning ? 'disabled' : ''}}"
          bindtap="onRescanStrategy"
        >
          <text class="params-icon">↻</text>
        </view>
        <view
          class="params-btn {{paramsCustomized ? 'active' : ''}}"
          bindtap="onOpenStrategyParams"
        >
          <text class="params-icon">⚙</text>
        </view>
      </view>

    </view>



    <view wx:if="{{recommendations.length === 0}}" class="empty-state">

      <text class="empty-icon">📭</text>

      <text class="empty-text">该策略暂无推荐</text>

      <text class="empty-hint">切换市场或其他策略查看更多标的</text>

    </view>



    <strategy-card

      wx:for="{{recommendations}}"

      wx:key="id"

      item="{{item}}"

      activePeriod="{{activePeriod}}"

      flipped="{{klineFlipped}}"

      bind:watchlist="onAddWatchlist"

      bind:ignore="onIgnore"

      bind:cardtap="onCardTap"

    />



    <view class="list-footer">

      <text wx:if="{{rescanning}}">策略重跑中…</text>
      <text wx:elif="{{loadingMore}}">加载中…</text>
      <text wx:elif="{{hasMore}}">上拉加载更多（{{recommendations.length}}/{{totalCount}}）</text>
      <text wx:else>— 左滑忽略 · 右滑自选 · 点击查看详情 —</text>

    </view>

  </view>



  <bottom-nav active="index" watchlistCount="{{watchlistCount}}" />

  <search-panel
    visible="{{searchVisible}}"
    watchlistIds="{{watchlistIds}}"
    statusBarHeight="{{statusBarHeight}}"
    bind:close="onSearchClose"
    bind:select="onSearchSelect"
    bind:addwatchlist="onSearchAddWatchlist"
  />

  <strategy-params-panel
    id="strategyParamsPanel"
    visible="{{paramsVisible}}"
    strategyId="{{activeStrategy}}"
    statusBarHeight="{{statusBarHeight}}"
    bind:close="onParamsClose"
    bind:apply="onParamsApply"
  />
</view>

