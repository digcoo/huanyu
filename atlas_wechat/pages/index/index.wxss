.page {
  min-height: 100vh;
  background: #0a0e17;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

.nav-sticky {
  position: sticky;
  top: 0;
  z-index: 101;
  background: #0a0e17;
  box-sizing: border-box;
}

.toolbar-sticky {
  position: sticky;
  z-index: 100;
  padding: 8rpx 0 10rpx;
  background: #0a0e17;
  border-bottom: 1rpx solid #2b2f36;
  box-sizing: border-box;
}

.toolbar-inner {
  margin: 0 24rpx;
  box-sizing: border-box;
}

.toolbar-inner strategy-tabs {
  display: block;
  width: 100%;
}

.nav-content {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 32rpx 8rpx;
}

.search-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
}

.search-icon {
  font-size: 34rpx;
  color: #848e9c;
  line-height: 1;
}

.brand {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-logo {
  font-size: 44rpx;
  color: #00d4ff;
  text-shadow: 0 0 20rpx rgba(0, 212, 255, 0.5);
}

.brand-text {
  display: flex;
  flex-direction: column;
}

.brand-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #e8edf5;
  letter-spacing: 4rpx;
}

.brand-sub {
  font-size: 20rpx;
  color: #5c6578;
  letter-spacing: 2rpx;
}

.chart-block {
  margin: 0 24rpx 8rpx;
  box-sizing: border-box;
}

.market-panel {
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
  overflow: hidden;
  background: #1e2026;
}

.market-panel .index-chart {
  padding: 0;
  background: transparent;
}

.market-panel .index-tabs {
  padding: 8rpx 8rpx 0;
  background: #0a0e17;
}

.market-panel .mini-kline.size-card {
  margin: 0;
  border: none;
  border-radius: 0;
  background: transparent;
}
.period-bar {
  padding: 0 0 8rpx;
  background: transparent;
  box-sizing: border-box;
}

.period-bar .period-switcher {
  width: 100%;
  padding: 0;
  margin: 0;
  box-sizing: border-box;
}

.period-bar .period-toolbar {
  width: 100%;
  gap: 8rpx;
  box-sizing: border-box;
}

.period-bar .period-tabs {
  flex: 1;
  min-width: 0;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
}

.period-bar .flip-btn {
  height: 56rpx;
  width: 56rpx;
}

.recommend-list {
  padding: 0 24rpx;
}

.list-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
  padding: 8rpx 8rpx 10rpx;
}

.list-header-main {
  flex: 1;
  min-width: 0;
}

.list-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.list-total {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 600;
  color: #00d4ff;
  font-variant-numeric: tabular-nums;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(0, 212, 255, 0.08);
  border: 1rpx solid rgba(0, 212, 255, 0.15);
  line-height: 1.3;
}

.list-params {
  display: block;
  margin-top: 6rpx;
  font-size: 20rpx;
  color: #848e9c;
}

.list-header-actions {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-shrink: 0;
}

.params-btn {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
}

.params-btn.rescan-btn .params-icon {
  font-size: 32rpx;
}

.params-btn.disabled {
  opacity: 0.45;
  pointer-events: none;
}

.params-btn.active {
  border-color: rgba(240, 185, 11, 0.5);
  background: rgba(240, 185, 11, 0.08);
}

.params-icon {
  font-size: 28rpx;
  color: #848e9c;
  line-height: 1;
}

.params-btn.active .params-icon {
  color: #f0b90b;
}

.list-subtitle {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  color: #5c6578;
  line-height: 1.5;
}

.list-badge {
  font-size: 20rpx;
  font-weight: 700;
  color: #0a0e17;
  background: linear-gradient(135deg, #00d4ff, #0099cc);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  letter-spacing: 2rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #8b95a8;
}

.empty-hint {
  font-size: 22rpx;
  color: #5c6578;
  margin-top: 8rpx;
}

.list-footer {
  text-align: center;
  padding: 24rpx 0 16rpx;
}

.list-footer text {
  font-size: 20rpx;
  color: #3d4556;
}

.back-top-btn {
  position: fixed;
  right: 28rpx;
  bottom: calc(120rpx + env(safe-area-inset-bottom));
  z-index: 99;
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: rgba(30, 32, 38, 0.92);
  border: 1rpx solid #2b2f36;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.35);
}

.back-top-btn-hover {
  background: rgba(0, 212, 255, 0.12);
  border-color: rgba(0, 212, 255, 0.45);
}

.back-top-icon {
  font-size: 32rpx;
  font-weight: 600;
  color: #00d4ff;
  line-height: 1;
}
