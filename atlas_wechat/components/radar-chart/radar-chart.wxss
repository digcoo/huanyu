.radar-chart {
  width: 100%;
}

.radar-wrap {
  position: relative;
  width: 100%;
  height: 360rpx;
  margin: 0 auto;
}

.radar-bg {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 280rpx;
  height: 280rpx;
  transform: translate(-50%, -50%);
}

.ring {
  position: absolute;
  left: 50%;
  top: 50%;
  border: 1rpx solid rgba(43, 47, 54, 0.9);
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.ring-1 { width: 35%; height: 35%; }
.ring-2 { width: 65%; height: 65%; }
.ring-3 { width: 95%; height: 95%; }

.axis {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 1rpx;
  height: 47.5%;
  background: rgba(43, 47, 54, 0.6);
  transform-origin: bottom center;
}

.axis-0 { transform: translate(-50%, -100%) rotate(0deg); }
.axis-1 { transform: translate(-50%, -100%) rotate(72deg); }
.axis-2 { transform: translate(-50%, -100%) rotate(144deg); }
.axis-3 { transform: translate(-50%, -100%) rotate(216deg); }
.axis-4 { transform: translate(-50%, -100%) rotate(288deg); }

.radar-layer {
  position: absolute;
  inset: 0;
}

.radar-dot {
  position: absolute;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  transform: translate(-50%, -50%);
}

.radar-layer.industry .radar-dot {
  background: rgba(132, 142, 156, 0.7);
  box-shadow: 0 0 6rpx rgba(132, 142, 156, 0.5);
}

.radar-layer.company .radar-dot {
  background: #0ecb81;
  box-shadow: 0 0 8rpx rgba(14, 203, 129, 0.6);
}

.radar-labels {
  position: absolute;
  inset: 0;
}

.lbl {
  position: absolute;
  font-size: 18rpx;
  color: #848e9c;
  transform: translate(-50%, -50%);
}

.lbl-0 { left: 50%; top: 6%; }
.lbl-1 { left: 88%; top: 38%; }
.lbl-2 { left: 76%; top: 82%; }
.lbl-3 { left: 24%; top: 82%; }
.lbl-4 { left: 12%; top: 38%; }

.radar-legend {
  display: flex;
  justify-content: center;
  gap: 32rpx;
  margin: 8rpx 0 16rpx;
}

.leg-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 22rpx;
  color: #848e9c;
}

.leg-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.leg-dot.company { background: #0ecb81; }
.leg-dot.industry { background: #848e9c; }

.compare-table {
  background: #161a1e;
  border-radius: 8rpx;
  overflow: hidden;
}

.table-head, .table-row {
  display: flex;
  padding: 12rpx 16rpx;
}

.table-head {
  background: rgba(43, 47, 54, 0.5);
  font-size: 20rpx;
  color: #848e9c;
}

.table-row {
  border-top: 1rpx solid #2b2f36;
  font-size: 22rpx;
}

.col {
  flex: 1;
  text-align: center;
  color: #e8edf5;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.col.dim {
  text-align: left;
  font-family: inherit;
  color: #848e9c;
}

.col.win { color: #0ecb81; }
.col.muted { color: #5c6578; }

.insight-list {
  margin-top: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.insight-row {
  display: flex;
  align-items: flex-start;
  gap: 10rpx;
}

.insight-tag {
  flex-shrink: 0;
  font-size: 18rpx;
  padding: 2rpx 10rpx;
  border-radius: 4rpx;
  font-weight: 600;
}

.insight-tag.win {
  color: #0ecb81;
  background: rgba(14, 203, 129, 0.12);
}

.insight-tag.warn {
  color: #f0b90b;
  background: rgba(240, 185, 11, 0.12);
}

.insight-text {
  flex: 1;
  font-size: 22rpx;
  color: #8b95a8;
  line-height: 1.5;
}
