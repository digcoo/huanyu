.index-chart {
  background: #0a0e17;
  padding: 0;
  border-bottom: none;
}

.index-tabs {
  display: flex;
  gap: 8rpx;
  padding: 8rpx 0 0;
}

.index-tab {
  flex: 1;
  padding: 10rpx 12rpx;
  border-radius: 8rpx;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
}

.index-tab.active {
  background: #2b2f36;
  border-color: rgba(240, 185, 11, 0.35);
}

.index-name {
  display: block;
  font-size: 20rpx;
  color: #848e9c;
  margin-bottom: 4rpx;
}

.index-tab.active .index-name {
  color: #f0b90b;
}

.index-price {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #e8edf5;
  font-variant-numeric: tabular-nums;
}

.index-change {
  display: block;
  font-size: 18rpx;
  margin-top: 2rpx;
  font-variant-numeric: tabular-nums;
}

.index-change.up { color: #f6465d; }
.index-change.down { color: #0ecb81; }

.index-chart mini-kline {
  display: block;
}

.index-chart .mini-kline.size-card {
  margin-top: 0;
  border-top: none;
  border-radius: 0;
}

.chart-empty {
  padding: 24rpx 8rpx;
  text-align: center;
  font-size: 22rpx;
  color: #848e9c;
  background: #1e2026;
}
