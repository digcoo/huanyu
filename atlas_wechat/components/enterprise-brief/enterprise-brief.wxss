.enterprise-brief {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  padding: 20rpx;
}

.brief-block {
  margin-bottom: 16rpx;
}

.brief-block:last-of-type {
  margin-bottom: 20rpx;
}

.brief-label {
  display: block;
  font-size: 20rpx;
  color: #00d4ff;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.brief-text {
  display: block;
  font-size: 24rpx;
  color: #c8d0dc;
  line-height: 1.65;
}

.brief-meta {
  display: block;
  font-size: 20rpx;
  color: #5c6578;
  margin-top: 8rpx;
}

.scope-block {
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-top: 14rpx;
  margin-top: 4rpx;
}

.scope-text {
  font-size: 22rpx;
  color: #8b95a8;
  line-height: 1.55;
}

.scope-toggle {
  text-align: center;
  padding: 8rpx 0 4rpx;
}

.scope-toggle text {
  font-size: 20rpx;
  color: #5c6578;
}

.dimension-section {
  margin-bottom: 16rpx;
  padding: 14rpx 0 4rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
}

.dimension-head {
  display: block;
  font-size: 20rpx;
  color: #f0b90b;
  font-weight: 600;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
}

.dimension-item {
  margin-bottom: 12rpx;
}

.dim-label {
  display: block;
  font-size: 22rpx;
  color: #e8edf5;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.dim-text {
  display: block;
  font-size: 22rpx;
  color: #8b95a8;
  line-height: 1.55;
}

.brief-row {
  display: flex;
  gap: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.06);
  padding-top: 16rpx;
}

.brief-col {
  flex: 1;
  min-width: 0;
}

.col-title {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.strengths .col-title {
  color: #0ecb81;
}

.risks .col-title {
  color: #f6465d;
}

.bullet-item {
  display: flex;
  align-items: flex-start;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.bullet-dot {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.4;
  flex-shrink: 0;
}

.strengths .bullet-dot {
  color: #0ecb81;
}

.risks .bullet-dot {
  color: #f6465d;
}

.bullet-text {
  font-size: 22rpx;
  color: #8b95a8;
  line-height: 1.45;
}
