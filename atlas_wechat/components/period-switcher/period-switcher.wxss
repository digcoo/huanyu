.period-switcher {
  padding: 0 8rpx 4rpx;
  margin-bottom: 0;
  margin-top: 0;
}

.period-toolbar {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.period-tabs {
  display: flex;
  flex: 1;
  min-width: 0;
  background: #1e2026;
  border-radius: 10rpx;
  border: 1rpx solid #2b2f36;
  padding: 4rpx;
  gap: 4rpx;
}

.period-tab {
  flex: 1;
  text-align: center;
  font-size: 24rpx;
  color: #848e9c;
  padding: 8rpx 0;
  border-radius: 8rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
  transition: all 0.15s;
}

.period-tab.active {
  background: #2b2f36;
  color: #f0b90b;
  font-weight: 600;
}

.flip-btn {
  flex-shrink: 0;
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 8rpx;
  transition: all 0.15s;
}

.flip-btn.active {
  border-color: rgba(240, 185, 11, 0.6);
  background: rgba(240, 185, 11, 0.1);
}

.flip-icon {
  font-size: 28rpx;
  color: #848e9c;
  line-height: 1;
}

.flip-btn.active .flip-icon {
  color: #f0b90b;
}
