.strategy-tabs {
  width: 100%;
  box-sizing: border-box;
}

.tabs-row {
  display: flex;
  width: 100%;
  gap: 8rpx;
  box-sizing: border-box;
}

.tab-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 88rpx;
  padding: 10rpx 4rpx;
  border-radius: 12rpx;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  box-sizing: border-box;
}

.tab-item.active {
  background: rgba(0, 212, 255, 0.1);
  border-color: rgba(0, 212, 255, 0.45);
  box-shadow: 0 0 16rpx rgba(0, 212, 255, 0.12);
}

.tab-icon {
  font-size: 30rpx;
  line-height: 1.2;
  margin-bottom: 4rpx;
}

.tab-name {
  font-size: 22rpx;
  color: #848e9c;
  font-weight: 500;
  text-align: center;
  line-height: 1.3;
}

.tab-item.active .tab-name {
  color: #00d4ff;
  font-weight: 600;
}
