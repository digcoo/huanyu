.search-mask {
  position: fixed;
  inset: 0;
  z-index: 1000;
  background: rgba(10, 14, 23, 0.92);
}

.search-panel {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
  background: #0a0e17;
}

.search-head {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 12rpx 24rpx 16rpx;
  border-bottom: 1rpx solid #2b2f36;
}

.search-input-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  height: 72rpx;
  padding: 0 20rpx;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
}

.search-input-icon {
  font-size: 32rpx;
  color: #848e9c;
  line-height: 1;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 28rpx;
  color: #e8edf5;
}

.search-placeholder {
  color: #5c6578;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #848e9c;
  line-height: 1;
}

.search-cancel {
  flex-shrink: 0;
  font-size: 28rpx;
  color: #848e9c;
  padding: 8rpx 0;
}

.search-body {
  flex: 1;
  min-height: 0;
  padding: 16rpx 24rpx 32rpx;
  box-sizing: border-box;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 24rpx;
  color: #848e9c;
}

.section-action {
  font-size: 24rpx;
  color: #5c6578;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.history-chip {
  padding: 10rpx 20rpx;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #c8d0dc;
}

.result-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.result-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #161a1e;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
}

.result-main {
  flex: 1;
  min-width: 0;
}

.result-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 6rpx;
}

.result-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #e8edf5;
}

.result-tag {
  font-size: 20rpx;
  color: #f0b90b;
  padding: 2rpx 10rpx;
  background: rgba(240, 185, 11, 0.12);
  border-radius: 6rpx;
}

.result-meta {
  font-size: 22rpx;
  color: #848e9c;
}

.result-side {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  flex-shrink: 0;
}

.result-price {
  font-size: 28rpx;
  color: #e8edf5;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.result-change {
  font-size: 22rpx;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.result-change.up { color: #0ecb81; }
.result-change.down { color: #f6465d; }

.result-add {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  font-size: 22rpx;
  color: #f0b90b;
  background: rgba(240, 185, 11, 0.1);
  border: 1rpx solid rgba(240, 185, 11, 0.35);
  border-radius: 8rpx;
}

.search-empty,
.search-hint {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 56rpx;
  color: #3d4556;
  margin-bottom: 20rpx;
}

.empty-title,
.hint-title {
  font-size: 30rpx;
  color: #c8d0dc;
  margin-bottom: 12rpx;
}

.empty-desc,
.hint-desc {
  font-size: 24rpx;
  color: #5c6578;
  line-height: 1.5;
}

.hint-examples {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx;
  margin-top: 28rpx;
}

.hint-chip {
  padding: 10rpx 20rpx;
  background: #1e2026;
  border: 1rpx solid #2b2f36;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #848e9c;
}
