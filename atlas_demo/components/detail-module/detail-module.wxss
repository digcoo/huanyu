.detail-module {
  background: #141b26;
  border: 1rpx solid #2b2f36;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.module-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 20rpx 20rpx 0;
}

.head-left {
  display: flex;
  align-items: flex-start;
  flex: 1;
  gap: 16rpx;
  min-width: 0;
}

.head-text {
  flex: 1;
  min-width: 0;
}

.title-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.kpi-badge {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
  background: rgba(43, 47, 54, 0.6);
}

.kpi-badge.up {
  background: rgba(14, 203, 129, 0.1);
}

.kpi-badge.down {
  background: rgba(246, 70, 93, 0.1);
}

.kpi-name {
  font-size: 18rpx;
  color: #848e9c;
}

.kpi-change {
  font-size: 18rpx;
  font-weight: 600;
  font-family: 'SF Mono', 'Menlo', monospace;
}

.kpi-badge.up .kpi-change { color: #0ecb81; }
.kpi-badge.down .kpi-change { color: #f6465d; }
.kpi-badge.flat .kpi-change { color: #848e9c; }

.color-bar {
  width: 6rpx;
  height: 48rpx;
  border-radius: 0 4rpx 4rpx 0;
  flex-shrink: 0;
}

.module-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e8edf5;
}

.module-insight {
  display: block;
  font-size: 20rpx;
  color: #5c6578;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  width: 100%;
}

.toggle-icon {
  font-size: 32rpx;
  color: #848e9c;
  padding: 0 20rpx;
  line-height: 1;
}

.module-body {
  padding: 0 20rpx 20rpx;
}

.insight-box {
  padding: 16rpx;
  background: rgba(43, 47, 54, 0.4);
  border-radius: 8rpx;
  border-left: 4rpx solid #2b2f36;
  margin-bottom: 16rpx;
}

.insight-text {
  font-size: 24rpx;
  color: #8b95a8;
  line-height: 1.7;
}
